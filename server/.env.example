# Server
PORT=5000
NODE_ENV=development

# Frontend origin, for CORS + Socket.IO allowed origins
CLIENT_URL=http://localhost:5173

# MongoDB (Atlas connection string or local)
MONGO_URI=mongodb://localhost:27017/viavoce

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Internal call to the FastAPI AI microservice - never exposed to the client
AI_SERVICE_URL=http://localhost:8000
