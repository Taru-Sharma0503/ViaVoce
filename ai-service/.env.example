# FastAPI server
PORT=8000
ENV=development

# Allowed origin - only the Node.js server should call this service directly
ALLOWED_ORIGIN=http://localhost:5000

# --- Speech-to-text: local faster-whisper, no API key ---
# Model size: tiny | base | small | medium | large-v3
# Bigger = more accurate, slower, more RAM. "base" is a good hackathon default.
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Sentence generation: Gemini free tier (optional), Ollama fallback ---
# If GEMINI_API_KEY is unset or the Gemini call fails, falls back to a
# local Ollama model, then to a simple deterministic template.
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Text-to-speech: local Piper, no API key ---
# Directory containing downloaded Piper voice models (.onnx + .onnx.json)
PIPER_VOICES_DIR=./voices

# Optional - path to a real trained sign-classification model checkpoint.
# Leave unset to use the built-in rule-based demo classifier.
SIGN_MODEL_PATH=